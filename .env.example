# Copy this file to .env.local for local development, or set the same
# variable in your hosting provider's environment settings (e.g. when the
# frontend is deployed separately from the backend).

# Base URL of the FastAPI backend (no trailing slash).
# Local dev default (matches `python backend/main.py`):
VITE_API_BASE_URL=http://localhost:8000

# Example for a backend deployed on Render:
# VITE_API_BASE_URL=https://elstrm-backend.onrender.com
